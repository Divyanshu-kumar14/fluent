// ─── Prisma Schema ─────────────────────────────────────────────
// Defines the database models for the Fluent TTS platform.
// Docs: https://pris.ly/d/prisma-schema

// ─── Performance tip ───────────────────────────────────────────
// Consider Prisma Accelerate for serverless / edge:
// https://pris.ly/cli/accelerate-init

// Generate the Prisma Client into src/generated/prisma
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// PostgreSQL is the backing datastore
datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────

/// Distinguishes built-in platform voices from user-uploaded custom voices.
enum VoiceVariant {
  SYSTEM
  CUSTOM
}

/// Describes the intended use-case / style of a voice.
enum VoiceCategory {
  AUDIOBOOK
  CONVERSATIONAL
  CUSTOMER_SERVICE
  GENERAL
  NARRATIVE
  CHARACTERS
  MEDITATION
  MOTIVATIONAL
  PODCAST
  ADVERTISING
  VOICEOVER
  CORPORATE
}

// ─── Models ────────────────────────────────────────────────────

/// A voice profile used as a reference for TTS generation.
/// SYSTEM voices are shared across all orgs; CUSTOM voices are org-scoped.
model Voice {
  id String @id @default(cuid())

  /// Null for SYSTEM voices; set to the owning org for CUSTOM voices.
  orgId String?

  name        String
  description String?
  category    VoiceCategory @default(GENERAL)
  language    String        @default("en-US")
  variant     VoiceVariant

  /// Object key in Cloudflare R2 pointing to the reference audio file.
  r2ObjectKey String?

  /// All TTS generations that used this voice.
  generations Generation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([variant])
  @@index([orgId])
}

/// A single TTS generation result.
/// Stores the input text, voice settings, and a reference to the output audio in R2.
model Generation {
  id String @id @default(cuid())

  /// The Clerk organisation that owns this generation.
  orgId String

  /// The voice used for this generation (nullable in case the voice is later deleted).
  voiceId String?
  voice   Voice?  @relation(fields: [voiceId], references: [id], onDelete: SetNull)

  text              String
  voiceName         String /// Denormalized snapshot of the voice name at generation time.
  r2ObjectKey       String? /// Set after the audio file is successfully uploaded to R2.
  temperature       Float
  topP              Float
  topK              Int
  repetitionPenalty Float

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orgId])
  @@index([voiceId])
}
